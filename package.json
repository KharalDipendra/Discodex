{
  "name": "codex-discord-rpc",
  "version": "0.1.0",
  "description": "Discord Rich Presence for Codex sessions.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codex-discord-rpc": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "setup:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-windows.ps1",
    "start": "npm run build && node dist/cli.js",
    "startup:install:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-windows-startup.ps1",
    "startup:uninstall:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-windows-startup.ps1",
    "test": "tsx --test test/*.test.ts",
    "watch:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/watch-codex-rpc.ps1"
  },
  "keywords": [
    "codex",
    "discord",
    "discord-rpc",
    "rich-presence",
    "openai"
  ],
  "author": "Codex Discord RPC contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "scripts",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "discord-rpc": "^4.0.1"
  },
  "devDependencies": {
    "@types/discord-rpc": "^4.0.11",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
